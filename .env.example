# Neon PostgreSQL connection string (SQLAlchemy async format)
PIC_DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.region.aws.neon.tech/pic?sslmode=verify-full

# Standard PostgreSQL URL for MCP server / CLI tools (same creds, no +asyncpg)
PIC_POSTGRES_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/pic?sslmode=verify-full

# Runtime environment
PIC_ENV=development  # development | staging | production | test

# Cloudflare R2 (S3-compatible object storage)
PIC_S3_BUCKET=pic-images
PIC_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
PIC_S3_ACCESS_KEY_ID=<r2-access-key>
PIC_S3_SECRET_ACCESS_KEY=<r2-secret-key>

# Embedding
PIC_DINOV2_MODEL=facebook/dinov2-base
PIC_EMBEDDING_BATCH_SIZE=32
PIC_PHASH_SIZE=16

# Clustering
PIC_L1_HASH_THRESHOLD=12
PIC_L2_MIN_CLUSTER_SIZE=5
PIC_L2_MIN_SAMPLES=3
PIC_L2_UMAP_N_COMPONENTS=25
PIC_L2_UMAP_N_NEIGHBORS=30

# API
PIC_API_KEY=  # Set a strong secret for production
PIC_AUTH_DISABLED=true  # Explicitly acknowledge unauthenticated mode in development
PIC_CORS_ORIGINS=["*"]  # Restrict to specific origins in production, e.g. ["https://app.example.com"]
PIC_CORS_ALLOW_CREDENTIALS=false  # Only set true with specific origins, never with ["*"]
PIC_MAX_UPLOAD_SIZE_MB=20
PIC_THUMBNAIL_WIDTH=256
PIC_THUMBNAIL_HEIGHT=256

# Observability (optional)
PIC_SENTRY_DSN=  # Sentry DSN for error tracking; empty = disabled

# Google Drive Sync (optional — empty = disabled)
PIC_GDRIVE_SERVICE_ACCOUNT_JSON=  # Service account JSON as string (not a file path)
PIC_GDRIVE_FOLDER_ID=             # Folder ID from URL: drive.google.com/drive/folders/{THIS_PART}
