# Neon PostgreSQL connection string (SQLAlchemy async format)
NIC_DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.region.aws.neon.tech/nic?sslmode=require

# Standard PostgreSQL URL for MCP server / CLI tools (same creds, no +asyncpg)
NIC_POSTGRES_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/nic?sslmode=require

# Cloudflare R2 (S3-compatible object storage)
NIC_S3_BUCKET=nic-images
NIC_S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
NIC_S3_ACCESS_KEY_ID=<r2-access-key>
NIC_S3_SECRET_ACCESS_KEY=<r2-secret-key>

# Embedding
NIC_DINOV2_MODEL=facebook/dinov2-base
NIC_EMBEDDING_BATCH_SIZE=32
NIC_PHASH_SIZE=16

# Clustering
NIC_L1_HASH_THRESHOLD=12
NIC_L2_MIN_CLUSTER_SIZE=5
NIC_L2_MIN_SAMPLES=3
NIC_L2_UMAP_N_COMPONENTS=25
NIC_L2_UMAP_N_NEIGHBORS=30

# API
NIC_API_KEY=  # Set a strong secret for production; empty = auth disabled (dev mode)
NIC_CORS_ORIGINS=["*"]  # Restrict to specific origins in production, e.g. ["https://app.example.com"]
NIC_CORS_ALLOW_CREDENTIALS=false  # Only set true with specific origins, never with ["*"]
NIC_MAX_UPLOAD_SIZE_MB=20
NIC_THUMBNAIL_WIDTH=256
NIC_THUMBNAIL_HEIGHT=256

# Observability (optional)
NIC_SENTRY_DSN=  # Sentry DSN for error tracking; empty = disabled

# Google Drive Sync (optional — empty = disabled)
NIC_GDRIVE_SERVICE_ACCOUNT_JSON=  # Service account JSON as string (not a file path)
NIC_GDRIVE_FOLDER_ID=             # Folder ID from URL: drive.google.com/drive/folders/{THIS_PART}
